
<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OLAI（オーライ）| 事務員、雇う前に。</title>
<meta name="description" content="職人管理・現場管理・支払管理を自動化。中小建設業向けAIバックオフィスSaaS。いつものようにLINEで指示するだけ。月14,800円〜。">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
<style>
:root{
  --green:#1B4332;
  --green-dark:#0F2A1F;
  --green-mid:#2D6A4F;
  --gold:#C9A961;
  --gold-bright:#E5C77A;
  --cream:#FAFAF7;
  --charcoal:#1A1A1A;
  --gray:#6B6B6B;
  --line-green:#06C755;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  font-family:'Noto Sans JP','Inter',-apple-system,sans-serif;
  background:var(--cream);
  color:var(--charcoal);
  line-height:1.7;
  -webkit-font-smoothing:antialiased;
}

/* NAV */
nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  background:rgba(250,250,247,.92);
  backdrop-filter:blur(12px);
  border-bottom:1px solid rgba(27,67,50,.08);
  padding:18px 5%;
  display:flex;justify-content:space-between;align-items:center;
}
.logo{
  font-weight:900;font-size:22px;color:var(--green);
  letter-spacing:.02em;
  display:flex;align-items:baseline;gap:6px;
}
.logo .kana{font-size:12px;color:var(--gray);font-weight:500}
.logo .dot{display:inline-block;width:6px;height:6px;background:var(--gold);border-radius:50%;margin-right:2px;transform:translateY(-4px)}
.nav-links{display:flex;gap:32px;align-items:center}
.nav-links a{color:var(--charcoal);text-decoration:none;font-size:14px;font-weight:500}
.nav-cta{
  background:var(--green);color:#fff!important;
  padding:10px 22px;border-radius:100px;
  font-size:13px;font-weight:700;
  transition:all .2s;
}
.nav-cta:hover{background:var(--green-dark);transform:translateY(-1px)}
@media(max-width:768px){.nav-links a:not(.nav-cta){display:none}}

/* HERO */
.hero{
  padding:140px 5% 100px;
  background:
    radial-gradient(ellipse at top right,rgba(201,169,97,.08),transparent 60%),
    radial-gradient(ellipse at bottom left,rgba(27,67,50,.04),transparent 50%),
    var(--cream);
  min-height:90vh;
  display:flex;align-items:center;
}
.hero-inner{
  max-width:1280px;margin:0 auto;
  display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;
}
.hero-tag{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(27,67,50,.06);
  color:var(--green);
  padding:8px 16px;border-radius:100px;
  font-size:13px;font-weight:600;
  margin-bottom:28px;
}
.hero-tag::before{
  content:'';width:6px;height:6px;background:var(--gold);border-radius:50%;
  animation:pulse 2s infinite;
}
@keyframes pulse{
  0%,100%{opacity:1;transform:scale(1)}
  50%{opacity:.5;transform:scale(1.4)}
}
.hero h1{
  font-size:clamp(40px,5.5vw,72px);
  font-weight:900;color:var(--green);
  line-height:1.15;letter-spacing:-.02em;
  margin-bottom:24px;
}
.hero h1 .accent{color:var(--gold)}
.hero-sub{
  font-size:clamp(18px,1.6vw,22px);
  color:var(--charcoal);font-weight:500;
  margin-bottom:16px;
}
.hero-mini{
  font-size:15px;color:var(--gray);
  margin-bottom:40px;
  display:flex;flex-wrap:wrap;gap:12px;align-items:center;
}
.hero-mini span{
  background:#fff;border:1px solid rgba(27,67,50,.12);
  padding:6px 14px;border-radius:8px;
  font-weight:600;color:var(--green);
}
.hero-ctas{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:32px}
.btn-primary{
  background:var(--green);color:#fff;
  padding:18px 36px;border-radius:100px;
  font-weight:700;font-size:16px;text-decoration:none;
  display:inline-flex;align-items:center;gap:8px;
  transition:all .25s;
  box-shadow:0 8px 24px rgba(27,67,50,.25);
}
.btn-primary:hover{background:var(--green-dark);transform:translateY(-2px);box-shadow:0 12px 32px rgba(27,67,50,.35)}
.btn-secondary{
  background:transparent;color:var(--green);
  padding:18px 32px;border-radius:100px;
  font-weight:700;font-size:16px;text-decoration:none;
  border:1.5px solid var(--green);
  transition:all .2s;
}
.btn-secondary:hover{background:var(--green);color:#fff}
.hero-trust{
  font-size:13px;color:var(--gray);
}
.hero-trust strong{color:var(--green)}

/* HERO PHONE MOCKUP */
.hero-visual{position:relative;display:flex;justify-content:center}
.phone{
  width:340px;
  background:#fff;
  border-radius:42px;
  padding:14px;
  box-shadow:0 30px 80px rgba(27,67,50,.25),0 0 0 2px rgba(27,67,50,.04);
  position:relative;
  z-index:2;
}
.phone-screen{
  background:#E8F2EC;
  border-radius:30px;
  overflow:hidden;
  height:560px;
  display:flex;flex-direction:column;
}
.line-header{
  background:var(--line-green);
  padding:14px 16px;
  display:flex;align-items:center;gap:10px;
  color:#fff;
}
.line-avatar{
  width:36px;height:36px;border-radius:50%;
  background:var(--green);color:var(--gold);
  display:flex;align-items:center;justify-content:center;
  font-weight:900;font-size:13px;
}
.line-info{flex:1}
.line-name{font-weight:700;font-size:14px}
.line-status{font-size:11px;opacity:.85}
.chat{
  flex:1;padding:16px 12px;
  display:flex;flex-direction:column;gap:10px;
  overflow:hidden;
}
.bubble{
  max-width:78%;
  padding:10px 14px;border-radius:16px;
  font-size:13px;line-height:1.5;
  animation:slideIn .5s ease-out backwards;
}
.bubble.user{
  background:#fff;align-self:flex-end;
  border-bottom-right-radius:4px;
  color:var(--charcoal);font-weight:500;
}
.bubble.bot{
  background:#fff;align-self:flex-start;
  border-bottom-left-radius:4px;
  color:var(--charcoal);
  border:1px solid rgba(27,67,50,.06);
}
.bubble.bot.list{
  background:#fff;
  font-family:'Inter',monospace;
}
.bubble.bot .b-title{color:var(--green);font-weight:700;margin-bottom:6px;display:flex;align-items:center;gap:4px}
.bubble.bot .b-row{display:flex;justify-content:space-between;padding:3px 0;font-size:12.5px}
.bubble.bot .b-row .name{color:var(--charcoal)}
.bubble.bot .b-row .amount{font-weight:700;color:var(--green)}
.bubble.bot .b-divider{border-top:1px dashed rgba(27,67,50,.2);margin:6px 0}
.bubble.bot .b-total{display:flex;justify-content:space-between;font-weight:800;color:var(--green);font-size:13px}
.bubble.bot .b-btn{
  display:block;text-align:center;margin-top:8px;
  background:var(--green);color:var(--gold);
  padding:8px;border-radius:8px;
  font-size:11.5px;font-weight:700;
}
.bubble:nth-child(1){animation-delay:.2s}
.bubble:nth-child(2){animation-delay:.5s}
.bubble:nth-child(3){animation-delay:1s}
.bubble:nth-child(4){animation-delay:1.3s}
@keyframes slideIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.line-input{
  background:#fff;padding:10px 14px;
  border-top:1px solid rgba(0,0,0,.06);
  color:var(--gray);font-size:12px;
}

/* Floating cards */
.float-card{
  position:absolute;
  background:#fff;
  padding:14px 18px;
  border-radius:14px;
  box-shadow:0 12px 32px rgba(27,67,50,.12);
  font-size:12px;font-weight:600;
  display:flex;align-items:center;gap:10px;
  z-index:1;
  animation:floaty 4s ease-in-out infinite;
}
.float-card .ico{
  width:32px;height:32px;border-radius:8px;
  background:rgba(27,67,50,.08);color:var(--green);
  display:flex;align-items:center;justify-content:center;
  font-size:16px;
}
.float-card.c1{top:8%;left:-8%;animation-delay:0s}
.float-card.c2{top:45%;left:-15%;animation-delay:1.5s}
.float-card.c3{bottom:10%;right:-8%;animation-delay:3s}
@keyframes floaty{
  0%,100%{transform:translateY(0)}
  50%{transform:translateY(-8px)}
}
@media(max-width:900px){
  .hero-inner{grid-template-columns:1fr;gap:60px}
  .float-card{display:none}
}

/* SOCIAL PROOF */
.proof{
  padding:50px 5%;
  background:#fff;
  border-top:1px solid rgba(27,67,50,.06);
  border-bottom:1px solid rgba(27,67,50,.06);
}
.proof-inner{
  max-width:1100px;margin:0 auto;
  text-align:center;
}
.proof-label{
  font-size:12px;color:var(--gray);
  letter-spacing:.15em;text-transform:uppercase;
  margin-bottom:24px;font-weight:600;
}
.proof-stats{
  display:grid;grid-template-columns:repeat(4,1fr);gap:20px;
}
.stat-num{
  font-size:36px;font-weight:900;color:var(--green);
  font-family:'Inter',sans-serif;
}
.stat-num .small{font-size:18px;color:var(--gold)}
.stat-label{font-size:13px;color:var(--gray);margin-top:4px}
@media(max-width:700px){.proof-stats{grid-template-columns:repeat(2,1fr);gap:30px}}

/* PROBLEM */
.problem{
  padding:120px 5%;
  background:var(--cream);
}
.problem-inner{max-width:1100px;margin:0 auto}
.section-label{
  display:inline-block;
  font-size:13px;font-weight:700;color:var(--gold);
  letter-spacing:.15em;text-transform:uppercase;
  margin-bottom:16px;
}
.section-title{
  font-size:clamp(32px,3.5vw,48px);
  font-weight:900;color:var(--green);
  line-height:1.25;letter-spacing:-.02em;
  margin-bottom:60px;
}
.problem-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:24px;
}
.problem-card{
  background:#fff;
  padding:36px 28px;
  border-radius:20px;
  border:1px solid rgba(27,67,50,.08);
  transition:all .3s;
}
.problem-card:hover{transform:translateY(-4px);box-shadow:0 20px 40px rgba(27,67,50,.08)}
.problem-card .num{
  font-family:'Inter',sans-serif;
  font-size:48px;font-weight:900;color:var(--gold);
  line-height:1;margin-bottom:16px;opacity:.4;
}
.problem-card h3{
  font-size:20px;font-weight:800;color:var(--green);
  margin-bottom:12px;
}
.problem-card p{
  color:var(--gray);font-size:15px;line-height:1.75;
}
@media(max-width:768px){.problem-grid{grid-template-columns:1fr}}

/* SOLUTION */
.solution{
  padding:120px 5%;
  background:var(--green);
  color:#fff;
  position:relative;overflow:hidden;
}
.solution::before{
  content:'';position:absolute;
  top:-50%;right:-20%;width:80%;height:200%;
  background:radial-gradient(circle,rgba(201,169,97,.08),transparent 60%);
  pointer-events:none;
}
.solution-inner{max-width:1200px;margin:0 auto;position:relative}
.solution .section-label{color:var(--gold)}
.solution .section-title{color:#fff}
.solution-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:24px;
  margin-top:60px;
}
.sol-card{
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.1);
  padding:40px 32px;
  border-radius:20px;
  backdrop-filter:blur(10px);
  transition:all .3s;
}
.sol-card:hover{
  background:rgba(255,255,255,.07);
  border-color:rgba(201,169,97,.5);
  transform:translateY(-4px);
}
.sol-card .ico{
  width:56px;height:56px;
  background:var(--gold);color:var(--green);
  border-radius:14px;
  display:flex;align-items:center;justify-content:center;
  font-size:26px;font-weight:900;
  margin-bottom:24px;
}
.sol-card h3{
  font-size:22px;font-weight:800;
  margin-bottom:12px;
}
.sol-card p{color:rgba(255,255,255,.75);font-size:15px;line-height:1.75}
.sol-card .demo{
  margin-top:20px;padding:12px 14px;
  background:rgba(0,0,0,.25);
  border-radius:10px;
  font-family:'Inter',monospace;font-size:12.5px;
  color:var(--gold-bright);
  border-left:2px solid var(--gold);
}
@media(max-width:900px){.solution-grid{grid-template-columns:1fr}}

/* HOW IT WORKS */
.how{padding:120px 5%;background:var(--cream)}
.how-inner{max-width:1100px;margin:0 auto}
.how-steps{
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:20px;margin-top:60px;
  position:relative;
}
.step{
  background:#fff;padding:32px 24px;
  border-radius:18px;text-align:center;
  border:1px solid rgba(27,67,50,.08);
  position:relative;
}
.step .step-num{
  position:absolute;top:-18px;left:50%;transform:translateX(-50%);
  width:36px;height:36px;border-radius:50%;
  background:var(--green);color:var(--gold);
  display:flex;align-items:center;justify-content:center;
  font-weight:900;font-size:15px;
  font-family:'Inter',sans-serif;
}
.step h4{font-size:16px;color:var(--green);margin:14px 0 8px;font-weight:800}
.step p{font-size:13px;color:var(--gray)}
@media(max-width:800px){.how-steps{grid-template-columns:repeat(2,1fr)}}

/* PRICING */
.pricing{padding:120px 5%;background:#fff}
.pricing-inner{max-width:1100px;margin:0 auto}
.price-grid{
  display:grid;grid-template-columns:repeat(2,1fr);gap:28px;margin-top:60px;
}
.price-card{
  background:var(--cream);
  padding:48px 40px;
  border-radius:24px;
  border:1px solid rgba(27,67,50,.08);
  position:relative;
}
.price-card.featured{
  background:var(--green);color:#fff;
  border:none;
  box-shadow:0 30px 60px rgba(27,67,50,.25);
}
.price-card.featured h3,.price-card.featured .amount{color:#fff}
.price-card .badge{
  position:absolute;top:24px;right:24px;
  background:var(--gold);color:var(--green);
  padding:6px 14px;border-radius:100px;
  font-size:11px;font-weight:800;
  letter-spacing:.05em;
}
.price-card h3{font-size:20px;font-weight:800;color:var(--green);margin-bottom:8px}
.price-card .desc{font-size:14px;opacity:.7;margin-bottom:24px}
.price-card .amount{
  font-size:48px;font-weight:900;color:var(--green);
  font-family:'Inter',sans-serif;line-height:1;
}
.price-card .amount .unit{font-size:18px;font-weight:500;opacity:.6;margin-left:4px}
.price-card ul{list-style:none;margin:32px 0;padding:0}
.price-card li{
  padding:10px 0;font-size:14.5px;
  display:flex;align-items:flex-start;gap:10px;
  border-bottom:1px dashed rgba(255,255,255,.1);
}
.price-card:not(.featured) li{border-color:rgba(27,67,50,.1)}
.price-card li::before{
  content:'✓';color:var(--gold);font-weight:900;flex-shrink:0;
}
.price-card .price-cta{
  display:block;text-align:center;
  padding:16px;border-radius:100px;
  font-weight:700;text-decoration:none;
  transition:all .2s;
}
.price-card:not(.featured) .price-cta{
  background:var(--green);color:#fff;
}
.price-card.featured .price-cta{
  background:var(--gold);color:var(--green);
}
.price-card .price-cta:hover{transform:translateY(-2px)}
@media(max-width:768px){.price-grid{grid-template-columns:1fr}}

/* CTA */
.cta{
  padding:100px 5%;
  background:var(--green-dark);
  color:#fff;text-align:center;
  position:relative;overflow:hidden;
}
.cta::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(circle at center,rgba(201,169,97,.1),transparent 60%);
}
.cta-inner{position:relative;max-width:800px;margin:0 auto}
.cta h2{
  font-size:clamp(36px,4.5vw,56px);
  font-weight:900;line-height:1.2;
  margin-bottom:20px;letter-spacing:-.02em;
}
.cta h2 .gold{color:var(--gold)}
.cta p{font-size:18px;opacity:.85;margin-bottom:40px}
.cta .btn-primary{
  background:var(--gold);color:var(--green);
  font-size:17px;padding:20px 44px;
}
.cta .btn-primary:hover{background:var(--gold-bright)}

/* FOOTER */
footer{
  background:#0F1F18;color:rgba(255,255,255,.6);
  padding:60px 5% 40px;
  font-size:13px;
}
.footer-inner{
  max-width:1200px;margin:0 auto;
  display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;
  margin-bottom:40px;
}
.footer-brand .logo{color:#fff;margin-bottom:14px}
.footer-brand p{max-width:300px;line-height:1.7}
.footer-col h5{color:#fff;font-size:14px;margin-bottom:14px;font-weight:700}
.footer-col a{display:block;color:rgba(255,255,255,.55);text-decoration:none;padding:4px 0}
.footer-col a:hover{color:var(--gold)}
.footer-bottom{
  border-top:1px solid rgba(255,255,255,.08);
  padding-top:30px;text-align:center;
  font-size:12px;
}
@media(max-width:800px){.footer-inner{grid-template-columns:1fr 1fr;gap:30px}}
</style>
</head>
<body>

