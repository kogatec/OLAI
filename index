<!-- SOCIAL PROOF -->
<section class="proof">
  <div class="proof-inner">
    <div class="proof-label">中小建設業のリアルな課題を、すべてLINEで</div>
    <div class="proof-stats">
      <div><div class="stat-num">40<span class="small">万社</span></div><div class="stat-label">国内 中小建設業者</div></div>
